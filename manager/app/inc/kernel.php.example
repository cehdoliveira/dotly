<?php
// ===== TIMEZONE E ENCODING =====
date_default_timezone_set("America/Sao_Paulo");
ini_set("default_charset", "UTF-8");

// ===== BANCO DE DADOS =====
// AVISO: Copie este arquivo para kernel.php e preencha com suas credenciais reais.
// NUNCA commite kernel.php com dados sensíveis.
define("DB_HOST", "mysql");
define("DB_NAME", "db_dotly");
define("DB_USER", "user_dotly");
define("DB_PASS", "SUA_SENHA_AQUI");

// ===== REDIS =====
define("REDIS_HOST", "redis");
define("REDIS_PORT", 6379);
define("REDIS_PREFIX", "dotly:manager:");
define("REDIS_DATABASE", 0);
define("REDIS_ENABLED", true);
define("REDIS_DEFAULT_TTL", 3600);

// ===== KAFKA =====
define("KAFKA_HOST", "kafka");
define("KAFKA_PORT", "9092");
define("KAFKA_TOPIC_EMAIL", "dotly_manager_emails");
define("KAFKA_CONSUMER_GROUP", "dotly-manager-email-worker-group");

// ===== EMAIL (SMTP) =====
define("mail_from_name", "dotly Manager");
define("mail_from_mail", "seu_email@exemplo.com");
define("mail_from_host", "smtp.gmail.com");
define("mail_from_port", "587");
define("mail_from_user", "seu_email@exemplo.com");
define("mail_from_pwd", "SUA_APP_PASSWORD_AQUI");
define("mail_encryption", "tls");

// ===== CONTATO (WhatsApp) =====
// Numero unico da plataforma (footer, tela de pago, e-mails). Trocar aqui
// atualiza tudo. whatsapp_number = so digitos (DDI+DDD+numero) para wa.me;
// whatsapp_display = como aparece pro cliente.
define("whatsapp_number", "5511999999999");
define("whatsapp_display", "+55 (11) 99999-9999");

// ===== APLICAÇÃO =====
define("cAppKey", "dotly_manager_session");
define("cTitle", "dotly Manager");
// Marca da LOJA (voltada ao cliente) — MESMO valor do site, NAO o titulo do painel.
// order_shipped e disparado no manager; usa esta constante para nao vazar o nome
// do painel pro cliente.
define("cStoreName", "Sua Loja");
define("cAppRoot", "/");
define("cRootServer", sprintf("%s%s", $_SERVER["DOCUMENT_ROOT"], constant("cAppRoot")));
define("cRootServer_APP", sprintf("%s%s", $_SERVER["DOCUMENT_ROOT"], constant("cAppRoot") . "../app"));

// Detecta HTTPS mesmo atrás de reverse proxy (Traefik com SSL termination).
// O Apache propaga X-Forwarded-Proto via SetEnvIf, populando $_SERVER['HTTPS'].
$_detected_protocol = 'http';
if (
    (!empty($_SERVER['HTTPS']) && strtolower($_SERVER['HTTPS']) !== 'off') ||
    (!empty($_SERVER['HTTP_X_FORWARDED_PROTO']) && strtolower($_SERVER['HTTP_X_FORWARDED_PROTO']) === 'https') ||
    (!empty($_SERVER['SERVER_PORT']) && (int)$_SERVER['SERVER_PORT'] === 443)
) {
    $_detected_protocol = 'https';
}
// ===== SEGURANÇA: ALLOWED_HOSTS =====
// Definido ANTES da validacao de Host abaixo (que usa esta constante) e antes de
// cFrontend (que deriva de HTTP_HOST). PRODUÇÃO: defina obrigatoriamente; se vazio
// E MANAGER_CANONICAL_URL vazio, canonical_url() lança exceção (fail closed) para
// impedir poisoning via Host header. Exemplo: "dotly.com.br,manager.dotly.com.br,www.dotly.com.br"
define("ALLOWED_HOSTS", "manager.dotly.local");

// Validar HTTP_HOST contra ALLOWED_HOSTS para prevenir Host Header Injection.
if (defined('ALLOWED_HOSTS') && constant('ALLOWED_HOSTS') !== '') {
	$allowedHosts = array_map('trim', explode(',', constant('ALLOWED_HOSTS')));
	$requestHost = $_SERVER["HTTP_HOST"] ?? '';
	if ($requestHost !== '' && !in_array($requestHost, $allowedHosts, true)) {
		header('HTTP/1.1 400 Bad Request');
		exit('Invalid host header');
	}
}
define("cFrontend", sprintf("%s://%s%s", $_detected_protocol, $_SERVER["HTTP_HOST"] ?? "localhost", constant("cAppRoot")));
unset($_detected_protocol);
define("cAssets", sprintf("%s%s", constant("cFrontend"), "assets/"));

define("DEFAULT_USER_PROFILE_ID", 2);
define("DEFAULT_ADMIN_PROFILE_ID", 1);
define("APP_VERSION", "1.8.1.0");

// ===== LOG =====
define("LOG_LEVEL", "info"); // debug, info, warning, error

// ===== UPLOAD =====
define("UPLOAD_DIR", "/var/www/dotly/manager/public_html/assets/upload/");
define("UPLOAD_MAX_SIZE", 10);
define("UPLOAD_ALLOWED_TYPES", "jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx");

// ===== SEGURANÇA =====
// URL canônica do painel manager — usada para links em e-mails de credenciais.
// DEVE ser definida explicitamente para evitar Host Header Injection.
// PRODUÇÃO: defina obrigatoriamente. Se vazio E ALLOWED_HOSTS vazio, canonical_url() lança
// exceção (fail closed) para impedir poisoning via Host header.
// Exemplo produção: "https://manager.dotly.com.br"
define("MANAGER_CANONICAL_URL", "http://manager.dotly.local");

// ===== SESSÃO =====
define("SESSION_LIFETIME", 7200);
define("SESSION_USE_REDIS", false);

// ===== INICIALIZAR REDIS =====
if (REDIS_ENABLED && class_exists("RedisCache")) {
    try {
        $GLOBALS["redis"] = RedisCache::getInstance();
    } catch (Exception $e) {
        error_log("Redis Error: " . $e->getMessage());
        $GLOBALS["redis"] = null;
    }
}
